# ── Database ──────────────────────────────────────────────────────────────────
# Neon: use the POOLED connection string for DATABASE_URL (ep-xxx-pooler.region...)
# and the DIRECT connection string for DIRECT_URL (ep-xxx.region...) — used for migrations/push
DATABASE_URL=
DIRECT_URL=

# ── NextAuth v5 (Auth.js) ─────────────────────────────────────────────────────
# IMPORTANT: NextAuth v5 uses AUTH_SECRET (not NEXTAUTH_SECRET)
# Generate with: openssl rand -base64 32  or  npx auth secret
AUTH_SECRET=
# For local dev, set this to your dev URL. On Vercel this is auto-detected.
AUTH_URL=http://localhost:3000

# ── Meilisearch ───────────────────────────────────────────────────────────────
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=masterkey

# ── Paystack ──────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_

# ── Pusher ────────────────────────────────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_SECRET=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=mt1

# ── Uploadthing ───────────────────────────────────────────────────────────────
UPLOADTHING_TOKEN=

# ── Resend ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_
RESEND_FROM_EMAIL=UniMart <no-reply@yourdomain.com>

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
PLATFORM_FEE_PERCENT=2.5
ESCROW_RELEASE_HOURS=48
